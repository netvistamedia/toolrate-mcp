  "author": "ToolRate <bleep@toolrate.ai>",
  "license": "MIT",
  "homepage": "https://toolrate.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netvistamedia/toolrate.git",
    "directory": "mcp/typescript"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
