    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "smoke": "node --test dist/test/smoke.test.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "toolrate",
    "claude-code",
    "cursor",
    "ai",
    "agents",
    "llm-router",
    "reliability"
