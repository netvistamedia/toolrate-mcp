{
  "name": "@toolrate/mcp-server",
  "version": "0.1.0",
  "description": "Official MCP server for ToolRate — let Claude Code, Cursor, and any MCP-compatible agent rate tools, route LLMs, and report outcomes natively.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "toolrate-mcp": "bin/toolrate-mcp"
  },
  "files": [
    "dist",
    "bin",
